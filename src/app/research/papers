"use client";

import { useState } from "react";
import { publications } from "@/lib/data/publications";
import PublicationCard from "@/components/PublicationCard";
import { Search, Filter, BarChart3, Clock, LayoutGrid, List as ListIcon } from "lucide-react";
import { motion } from "framer-motion";

export default function PublicationsPage() {
  const [filter, setFilter] = useState("All");
  const [search, setSearch] = useState("");

  const filteredPubs = publications.filter(p => {
    const matchesFilter = filter === "All" || p.type === filter;
    const matchesSearch = p.title.toLowerCase().includes(search.toLowerCase()) || 
                         p.summary.toLowerCase().includes(search.toLowerCase());
    return matchesFilter && matchesSearch;
  });

  const timelineEvents = [
    { year: "2026", title: "Eastern Drought Report Series", color: "#8B4513" },
    { year: "2025", title: "Berbera Corridor Economic Study", color: "#D2B48C" },
    { year: "2024", title: "Digital Inclusion Foundation Paper", color: "#1E3A8A" }
  ];

  return (
    <div className="flex flex-col min-h-screen bg-accent/20">
      <section className="bg-white dark:bg-[#0F172A] border-b border-secondary/10 py-24">
        <div className="container mx-auto px-6">
          <div className="flex flex-col md:flex-row md:items-end justify-between gap-12">
            <div className="max-w-2xl">
              <h1 className="text-6xl font-serif font-black text-primary dark:text-white mb-6 italic tracking-tighter">Strategic Library</h1>
              <p className="text-xl text-primary/70 dark:text-slate-400 font-medium italic leading-relaxed">
                A centralized repository of high-fidelity research, policy frameworks, and regional analysis produced by the XIDIGIS institute.
              </p>
            </div>
            
            {/* Interactive Timeline Preview */}
            <div className="flex items-center gap-4 bg-accent/50 p-6 rounded-sm border border-secondary/10">
              <Clock className="text-secondary shrink-0" />
              <div className="flex gap-8">
                {timelineEvents.map((event, i) => (
                  <div key={i} className="flex flex-col">
                    <span className="text-[10px] font-black text-primary uppercase tracking-widest italic">{event.year}</span>
                    <span className="text-[9px] font-bold text-secondary uppercase tracking-tighter truncate max-w-[80px] italic">{event.title}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <div className="container mx-auto px-6 py-24">
        <div className="grid grid-cols-1 lg:grid-cols-4 gap-16">
          
          {/* Sidebar Filters */}
          <div className="space-y-12">
            <div>
              <h4 className="text-[10px] font-black text-secondary uppercase tracking-[0.2em] mb-8 italic">Search Archive</h4>
              <div className="relative">
                <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-primary/30" size={18} />
                <input 
                  type="text" 
                  placeholder="Keywords..."
                  value={search}
                  onChange={(e) => setSearch(e.target.value)}
                  className="w-full pl-12 pr-4 py-4 bg-white dark:bg-slate-800 border border-secondary/20 rounded-sm text-sm font-medium italic focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                />
              </div>
            </div>

            <div>
              <h4 className="text-[10px] font-black text-secondary uppercase tracking-[0.2em] mb-8 italic">Output Categories</h4>
              <div className="flex flex-col gap-3">
                {["All", "Brief", "Paper", "Report"].map((type) => (
                  <button
                    key={type}
                    onClick={() => setFilter(type)}
                    className={`flex items-center justify-between px-6 py-4 rounded-sm font-black uppercase tracking-widest text-[10px] transition-all italic border ${
                      filter === type 
                      ? "bg-primary text-white border-primary shadow-lg shadow-primary/20" 
                      : "bg-white dark:bg-slate-800 text-primary dark:text-white border-secondary/10 hover:border-primary/40"
                    }`}
                  >
                    {type}s <span>{type === "All" ? publications.length : publications.filter(p => p.type === type).length}</span>
                  </button>
                ))}
              </div>
            </div>

            <div className="pt-12 border-t border-secondary/10">
              <div className="flex items-center gap-3 text-primary mb-6">
                <BarChart3 size={20} />
                <h4 className="text-[10px] font-black uppercase tracking-[0.2em] italic">Collection Stats</h4>
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div className="p-4 bg-white dark:bg-slate-800 border border-secondary/10 rounded-sm">
                  <span className="block text-xl font-serif font-black text-primary italic">156</span>
                  <span className="text-[8px] font-black uppercase tracking-widest text-primary/40">Total Citations</span>
                </div>
                <div className="p-4 bg-white dark:bg-slate-800 border border-secondary/10 rounded-sm">
                  <span className="block text-xl font-serif font-black text-primary italic">4k</span>
                  <span className="text-[8px] font-black uppercase tracking-widest text-primary/40">PDF Loads</span>
                </div>
              </div>
            </div>
          </div>

          {/* Library Grid */}
          <div className="lg:col-span-3 space-y-12">
            <div className="flex items-center justify-between mb-12">
              <div className="flex items-center gap-3">
                <Filter size={18} className="text-secondary" />
                <span className="text-[10px] font-black text-primary dark:text-white uppercase tracking-widest italic">Viewing {filteredPubs.length} Research Outputs</span>
              </div>
              <div className="flex gap-2">
                <button className="p-3 bg-white dark:bg-slate-800 border border-secondary/10 text-primary hover:text-secondary transition-colors" title="Grid View"><LayoutGrid size={16} /></button>
                <button className="p-3 bg-white dark:bg-slate-800 border border-secondary/10 text-primary hover:text-secondary transition-colors" title="List View"><ListIcon size={16} /></button>
              </div>
            </div>

            <div className="card-grid">
              {filteredPubs.map(pub => (
                <div key={pub.id} className="card-item">
                  <PublicationCard
                    id={pub.id}
                    slug={pub.link}
                    title={pub.title}
                    abstract={pub.summary}
                    author={pub.author}
                    date={pub.date}
                    category={pub.category}
                    type={pub.type}
                  />
                </div>
              ))}
            </div>

            {filteredPubs.length === 0 && (
              <div className="py-24 text-center">
                <p className="font-serif font-bold text-primary/30 text-2xl italic">No outputs match your strategic filter.</p>
              </div>
            )}
          </div>

        </div>
      </div>
    </div>
  );
}
